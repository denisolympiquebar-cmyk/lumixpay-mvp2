# ─── LumixPay Web — environment variables ─────────────────────────────────────
# Copy this file to apps/web/.env.local for local development.
# In production (Vercel) set these in the Vercel dashboard → Project → Settings → Environment Variables.
#
# IMPORTANT: All VITE_ variables are baked into the static bundle at build time.
#            Never put secrets here.

# ── API base URL ──────────────────────────────────────────────────────────────
# Development: leave unset — Vite dev proxy handles /api/* → http://localhost:4000
# Production:  set to your deployed Fly.io API URL (no trailing slash, no /api suffix)
VITE_API_BASE=https://lumixpay-api.fly.dev
