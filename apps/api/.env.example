# ─── LumixPay API — environment variables ─────────────────────────────────────
# Copy this file to .env (repo root) for local development.
# In production (Fly.io) set these via: fly secrets set KEY=value

# ── Server ─────────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=production

# ── Database ───────────────────────────────────────────────────────────────────
# Full connection string takes priority over individual vars
DATABASE_URL=postgresql://lumixpay:lumixpay_secret@localhost:5432/lumixpay

# Individual vars (used only when DATABASE_URL is not set)
# POSTGRES_USER=lumixpay
# POSTGRES_PASSWORD=lumixpay_secret
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
# POSTGRES_DB=lumixpay

# ── Auth ───────────────────────────────────────────────────────────────────────
# Generate a strong random secret:  openssl rand -hex 64
JWT_SECRET=change_this_to_a_long_random_secret
JWT_EXPIRES_IN=24h

# ── CORS ───────────────────────────────────────────────────────────────────────
# Set to your deployed frontend URL. Accepts * for development only.
CORS_ORIGIN=https://lumixpay.vercel.app

# ── VAPID (Push Notifications) ─────────────────────────────────────────────────
# Generate a VAPID key pair once:
#   npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=your_vapid_public_key_here
VAPID_PRIVATE_KEY=your_vapid_private_key_here
VAPID_SUBJECT=mailto:admin@lumixpay.com

# ── Admin seed ────────────────────────────────────────────────────────────────
# Set to true only on first deploy to create the initial admin account.
# Must also set SEED_ADMIN_EMAIL + SEED_ADMIN_PASSWORD + SEED_ADMIN_NAME.
LUMIX_SEED_ADMIN=false
# SEED_ADMIN_EMAIL=admin@lumixpay.com
# SEED_ADMIN_PASSWORD=change_this_admin_password
# SEED_ADMIN_NAME=LumixPay Admin

# ── Platform fee ─────────────────────────────────────────────────────────────
PLATFORM_FEE_RATE=0.01
