# ── PostgreSQL ──────────────────────────────────────────────────────────────
POSTGRES_USER=lumixpay
POSTGRES_PASSWORD=lumixpay_secret
POSTGRES_DB=lumixpay
POSTGRES_HOST=localhost
POSTGRES_PORT=5433

DATABASE_URL=postgres://lumixpay:lumixpay_secret@localhost:5433/lumixpay

# ── API ─────────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ── Auth ────────────────────────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_secret_in_production
JWT_EXPIRES_IN=24h

# ── Fee ─────────────────────────────────────────────────────────────────────
PLATFORM_FEE_RATE=0.01

