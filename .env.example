# ── PostgreSQL ──────────────────────────────────────────────────────────────
POSTGRES_USER=lumixpay
POSTGRES_PASSWORD=lumixpay_secret
POSTGRES_DB=lumixpay
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

DATABASE_URL=postgresql://lumixpay:lumixpay_secret@localhost:5432/lumixpay

# ── API ─────────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ── Auth ────────────────────────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_secret_in_production
JWT_EXPIRES_IN=24h

# ── Fee ─────────────────────────────────────────────────────────────────────
PLATFORM_FEE_RATE=0.01

# ── XRPL (Phase 2 — not used in Phase 1) ────────────────────────────────────
# XRPL_NETWORK=mainnet
# XRPL_NODE_URL=wss://xrplcluster.com

# ── Admin seed ───────────────────────────────────────────────────────────────
# Set LUMIX_SEED_ADMIN=true to automatically create/promote the admin account
# on API startup. Idempotent — safe to leave enabled; runs on every boot.
#
# !! NEVER commit real credentials. Keep this block in .env (gitignored) only !!
#
LUMIX_SEED_ADMIN=false
ADMIN_EMAIL=
ADMIN_PASSWORD=

# ── CORS ─────────────────────────────────────────────────────────────────────
# Space/comma-separated origins allowed to call the API. Defaults to * in dev.
CORS_ORIGIN=http://localhost:5173
